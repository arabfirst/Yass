modules = ["nodejs-20", "web", "python-3.11"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=5000 node --enable-source-maps artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "pnpm install --no-frozen-lockfile && pnpm --filter @workspace/my-website run build && pnpm --filter @workspace/api-server run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install --no-frozen-lockfile && pnpm --filter @workspace/my-website run build && PORT=5000 pnpm --filter @workspace/api-server run dev"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib"]

[userenv]

[userenv.shared]
AFPD_WEBSITE_URL = "https://website--AAFPD.replit.app"
AFPD_BOT_API_KEY = "AFPD-BOT-SYNC-KEY-2025"
ERLC_API_KEY = "vYSvEUctkaLZVnuEvnVn-LqWSMeyEkOTAKhBBAGRVEnPRzqpsQokBJQxjnWzQ"
ERLC_BASE_URL = "https://api.erlc.gg/v2"
BOT_WEBHOOK_URL = "http://fi5.bot-hosting.net:20170"
